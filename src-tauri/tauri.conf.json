{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sticker Nah",
  "version": "0.1.0",
  "identifier": "com.stickernah.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Sticker Nah",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 520,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.ico"],
    "resources": ["bin/win/*"]
  }
}
